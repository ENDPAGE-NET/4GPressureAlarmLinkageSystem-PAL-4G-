EMQX_NODE_NAME=emqx@127.0.0.1
EMQX_HOST=127.0.0.1
EMQX_DASHBOARD__DEFAULT_USERNAME=admin
EMQX_DASHBOARD__DEFAULT_PASSWORD=replace-emqx-dashboard-password
EMQX_LISTENERS__TCP__DEFAULT__BIND=0.0.0.0:1883
EMQX_LISTENERS__SSL__DEFAULT__BIND=0.0.0.0:8883
EMQX_LISTENERS__SSL__DEFAULT__SSL_OPTIONS__CERTFILE=/opt/pal4g/emqx/certs/fullchain.pem
EMQX_LISTENERS__SSL__DEFAULT__SSL_OPTIONS__KEYFILE=/opt/pal4g/emqx/certs/privkey.pem
EMQX_LISTENERS__SSL__DEFAULT__SSL_OPTIONS__CACERTFILE=/opt/pal4g/emqx/certs/ca.pem
EMQX_AUTHORIZATION__NO_MATCH=deny

# HTTP Auth Backend — 设备接入认证委托给 PAL_4G 后端
# 部署后需在 EMQX Dashboard -> Authentication 中添加 HTTP Server 认证器：
#   Method: POST
#   URL: http://127.0.0.1:8001/api/v1/mqtt/emqx/auth
#   Body: {"username":"${username}","password":"${password}","clientid":"${clientid}"}
#   Headers: Content-Type: application/json
#
# 如需 ACL 鉴权（可选，推荐开启）：
# EMQX Dashboard -> Authorization 中添加 HTTP Server 授权器：
#   Method: POST
#   URL: http://127.0.0.1:8001/api/v1/mqtt/emqx/acl
#   Body: {"username":"${username}","clientid":"${clientid}","topic":"${topic}","action":"${action}"}
